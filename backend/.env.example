APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Public URL of the Flutter Web SPA. Used by ShareController to build the
# canonical og:url and the human redirect inside /share/company/{id}.
WEB_URL=https://www.termini-im.com

# Public IP of the VPS that runs the Apache reverse proxy (the one in front
# of www.termini-im.com). Required so Laravel trusts X-Forwarded-For and the
# per-IP throttle on share.company works correctly. Leave blank in dev.
TRUSTED_PROXY_IP=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=LagediDB
DB_USERNAME=userDB
DB_PASSWORD=passwordDB

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@termini-im.local"
MAIL_FROM_NAME="Termini Im"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Social login — anti-replay checks
# Google: comma-separated list of OAuth client IDs that are authorised to
# issue tokens for this backend (web + android + iOS). Leave empty to skip
# the aud check (dev only — enable in production).
GOOGLE_ALLOWED_CLIENT_IDS=

# Apple: the Bundle ID (iOS app) or Service ID (web). Leave empty to skip
# the aud check (dev only — enable in production).
APPLE_CLIENT_ID=

VITE_APP_NAME="${APP_NAME}"
